{
	"mcpServers": {
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/",
			"headers": {
				"Authorization": "Bearer ${GITHUB_TOKEN}"
			}
		},
		"playwright": {
			"type": "stdio",
			"command": "bunx",
			"args": ["--bun", "-y", "@playwright/mcp"]
		},
		"svelte": {
			"type": "stdio",
			"command": "bunx",
			"args": ["--bun", "-y", "@sveltejs/mcp"]
		},
		"astro": {
			"type": "http",
			"url": "https://mcp.docs.astro.build/mcp"
		},
		"athsra": {
			"type": "stdio",
			"command": "athsra",
			"args": ["mcp"]
		}
	}
}
