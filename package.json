{
	"name": "modfolio-studio",
	"private": true,
	"workspaces": [
		"apps/*"
	],
	"packageManager": "bun@1.2.4",
	"scripts": {
		"build": "cd apps/landing && bun run build",
		"dev": "cd apps/landing && bun run dev",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"typecheck": "cd apps/landing && astro check"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8"
	}
}
