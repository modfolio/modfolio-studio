{
	"name": "modfolio-studio",
	"version": "0.1.0",
	"private": true,
	"workspaces": [
		"apps/*"
	],
	"packageManager": "bun@1.2.4",
	"scripts": {
		"quality:all": "bun run check && bun run typecheck && bun run typecheck:app && bash scripts/quality-gate.sh",
		"build": "cd apps/landing && bun run build",
		"build:app": "cd apps/app && bun run build",
		"dev": "cd apps/landing && bun run dev",
		"dev:app": "cd apps/app && bun run dev",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"typecheck": "echo 'root typecheck: astro check disabled until libuv/css-tree fix. see apps/*/check.'",
		"typecheck:astro": "cd apps/landing && bun run check",
		"typecheck:app": "cd apps/app && bun run check",
		"harness-pull": "modfolio-harness-pull"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@modfolio/harness": "^2.14.3"
	},
	"overrides": {
		"@biomejs/cli-linux-x64-musl": "npm:@biomejs/cli-linux-x64@^2.4.8"
	}
}
