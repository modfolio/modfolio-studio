---
import type { GetStaticPaths, InferGetStaticParamsType } from "astro";
import Base from "../../layouts/Base.astro";
import { getAllAppIds, getAppDetail } from "../../lib/app-details";

export const getStaticPaths = (() => {
	return getAllAppIds().map((id) => ({ params: { app: id } }));
}) satisfies GetStaticPaths;

type Params = InferGetStaticParamsType<typeof getStaticPaths>;
const { app: appId } = Astro.params as Params;
const detail = getAppDetail(appId);

if (!detail) {
	return Astro.redirect("/");
}
---

<Base
	title={`${detail.name} — Modfolio Studio`}
	description={`${detail.headline} ${detail.desc}`}
>
	<main id="main">
		<section class="app-hero" data-app={detail.id}>
			<div class="app-hero-glow"></div>
			<div class="app-hero-content">
				<nav class="breadcrumb" aria-label="현재 위치">
					<a href="/">Studio</a> <span aria-hidden="true">→</span>
					<a href="/apps">Apps</a> <span aria-hidden="true">→</span>
					<span>{detail.name}</span>
				</nav>
				<p class="app-hero-label">{detail.name}</p>
				<h1 class="app-hero-title">{detail.headline}</h1>
				<p class="app-hero-desc">{detail.desc}</p>
				<a href={`https://${detail.domain}`} class="app-hero-cta" target="_blank" rel="noopener">
					{detail.domain} 방문 →
				</a>
			</div>
		</section>

		<section class="features-section">
			<h2 class="section-heading">핵심 기능</h2>
			<div class="features-grid">
				{detail.features.map((f) => (
					<div class="feature-card" data-app={detail.id}>
						<h3 class="feature-title">{f.title}</h3>
						<p class="feature-desc">{f.desc}</p>
					</div>
				))}
			</div>
		</section>

		<section class="app-cta" data-app={detail.id}>
			<h2 class="app-cta-title">직접 써보세요.</h2>
			<a href={`https://${detail.domain}`} class="app-cta-btn" target="_blank" rel="noopener">
				{detail.domain} 방문
			</a>
		</section>
	</main>
</Base>

<style>
	/* ═══ App Hero ═══ */

	.breadcrumb {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		color: var(--color-text-3);
		margin-bottom: var(--space-6);
	}

	.breadcrumb a:hover { color: var(--color-text-1); }

	.app-hero {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 80vh;
		padding: var(--header-height) var(--layout-padding-x) var(--space-16);
		text-align: center;
		overflow: hidden;
	}

	.app-hero-glow {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.app-hero[data-app="munseo"] .app-hero-glow {
		background: radial-gradient(ellipse 50% 40% at 50% 50%, color-mix(in oklch, var(--color-app-munseo) 12%, transparent), transparent);
	}

	.app-hero[data-app="umbracast"] .app-hero-glow {
		background: radial-gradient(ellipse 50% 40% at 50% 50%, color-mix(in oklch, var(--color-app-umbracast) 12%, transparent), transparent);
	}

	.app-hero[data-app="sincheong"] .app-hero-glow {
		background: radial-gradient(ellipse 50% 40% at 50% 50%, color-mix(in oklch, var(--color-app-sincheong) 12%, transparent), transparent);
	}

	.app-hero-content {
		position: relative;
		max-width: var(--layout-max-width-mid);
	}

	.app-hero-label {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin-bottom: var(--space-4);
	}

	.app-hero[data-app="munseo"] .app-hero-label { color: var(--color-app-munseo); }
	.app-hero[data-app="umbracast"] .app-hero-label { color: var(--color-app-umbracast); }
	.app-hero[data-app="sincheong"] .app-hero-label { color: var(--color-app-sincheong); }

	.app-hero-title {
		font-family: var(--font-display);
		font-size: var(--font-size-display);
		font-weight: var(--font-weight-light);
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-4);
	}

	.app-hero-desc {
		font-family: var(--font-ui);
		font-size: var(--font-size-body);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-2);
		margin-bottom: var(--space-8);
	}

	.app-hero-cta {
		display: inline-block;
		font-family: var(--font-ui);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		text-decoration: none;
		padding: var(--space-3) var(--space-8);
		border-radius: var(--radius-full);
		transition:
			transform var(--dur-fast) var(--ease-smooth),
			box-shadow var(--dur-base) var(--ease-smooth);
	}

	.app-hero[data-app="munseo"] .app-hero-cta {
		color: var(--color-surface-0);
		background: var(--color-app-munseo);
	}

	.app-hero[data-app="umbracast"] .app-hero-cta {
		color: var(--color-surface-0);
		background: var(--color-app-umbracast);
	}

	.app-hero[data-app="sincheong"] .app-hero-cta {
		color: var(--color-surface-0);
		background: var(--color-app-sincheong);
	}

	.app-hero-cta:hover {
		transform: scale(1.05);
		box-shadow: 0 0 32px color-mix(in oklch, var(--color-accent-primary) 25%, transparent);
	}

	/* ═══ Features ═══ */

	.features-section {
		max-width: var(--layout-max-width);
		margin: 0 auto;
		padding: var(--space-20) var(--layout-padding-x);
	}

	.section-heading {
		font-family: var(--font-display);
		font-size: var(--font-size-h2);
		font-weight: var(--font-weight-light);
		text-align: center;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-12);
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-6);
	}

	.feature-card {
		padding: var(--space-8);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-lg);
		transition:
			border-color var(--dur-base) var(--ease-smooth),
			transform var(--dur-fast) var(--ease-smooth);
	}

	.feature-card:hover {
		transform: translateY(-3px);
	}

	.feature-card[data-app="munseo"]:hover { border-color: var(--color-app-munseo); }
	.feature-card[data-app="umbracast"]:hover { border-color: var(--color-app-umbracast); }
	.feature-card[data-app="sincheong"]:hover { border-color: var(--color-app-sincheong); }

	.feature-title {
		font-family: var(--font-display);
		font-size: var(--font-size-h3);
		font-weight: var(--font-weight-medium);
		margin-bottom: var(--space-3);
	}

	.feature-desc {
		font-family: var(--font-body);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-2);
		line-height: 1.7;
		max-width: 45ch;
	}

	/* ═══ App CTA ═══ */

	.app-cta {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 40vh;
		padding: var(--space-20) var(--layout-padding-x);
		text-align: center;
	}

	.app-cta-title {
		font-family: var(--font-display);
		font-size: var(--font-size-h1);
		font-weight: var(--font-weight-light);
		letter-spacing: -0.02em;
		margin-bottom: var(--space-8);
	}

	.app-cta-btn {
		display: inline-block;
		font-family: var(--font-ui);
		font-size: var(--font-size-body);
		font-weight: var(--font-weight-medium);
		color: var(--color-surface-0);
		text-decoration: none;
		padding: var(--space-4) var(--space-10);
		border-radius: var(--radius-full);
		transition:
			transform var(--dur-fast) var(--ease-smooth),
			box-shadow var(--dur-base) var(--ease-smooth);
	}

	.app-cta[data-app="munseo"] .app-cta-btn { background: var(--color-app-munseo); }
	.app-cta[data-app="umbracast"] .app-cta-btn { background: var(--color-app-umbracast); }
	.app-cta[data-app="sincheong"] .app-cta-btn { background: var(--color-app-sincheong); }

	.app-cta-btn:hover {
		transform: scale(1.05);
		box-shadow: 0 0 40px color-mix(in oklch, var(--color-accent-primary) 30%, transparent);
	}

	@media (max-width: 768px) {
		.features-grid { grid-template-columns: 1fr; }
		.usecases-grid { grid-template-columns: 1fr; }
	}
</style>
