---
import Base from "../../layouts/Base.astro";
import { STUDIO_APPS } from "../../lib/apps";
---

<Base
	title="앱 — Modfolio Studio"
	description="Studio의 세 가지 크리에이티브 도구: Munseo, Umbracast, Sincheong"
>
	<main>
		<section class="apps-hero">
			<h1 class="apps-title">Studio의 도구</h1>
			<p class="apps-subtitle">
				누구든 크리에이터가 될 수 있는 세 가지 유틸리티.
			</p>
		</section>

		<section class="apps-list">
			{
				STUDIO_APPS.map((app) => (
					<a href={`/apps/${app.id}`} class="app-card" data-app={app.id}>
						<div class="app-card-inner">
							<p class="app-card-label">{app.name}</p>
							<h2 class="app-card-headline">{app.headline}</h2>
							<p class="app-card-desc">{app.desc}</p>
							<span class="app-card-domain">{app.domain}</span>
						</div>
						<span class="app-card-arrow">→</span>
					</a>
				))
			}
		</section>
	</main>
</Base>

<style>
	.apps-hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 50vh;
		padding: var(--header-height) var(--layout-padding-x) var(--space-12);
		text-align: center;
	}

	.apps-title {
		font-family: var(--font-display);
		font-size: var(--font-size-display);
		font-weight: var(--font-weight-light);
		letter-spacing: -0.03em;
		margin-bottom: var(--space-4);
	}

	.apps-subtitle {
		font-family: var(--font-body);
		font-size: var(--font-size-body);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-2);
	}

	.apps-list {
		max-width: 800px;
		margin: 0 auto;
		padding: 0 var(--layout-padding-x) var(--space-24);
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	.app-card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: var(--space-8) var(--space-10);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-lg);
		text-decoration: none;
		color: var(--color-text-1);
		transition:
			border-color var(--dur-base) var(--ease-smooth),
			transform var(--dur-fast) var(--ease-smooth),
			box-shadow var(--dur-base) var(--ease-smooth),
			background var(--dur-base) var(--ease-smooth);
	}

	.app-card:hover {
		transform: translateY(-2px);
		background: var(--color-surface-raised);
		box-shadow: var(--shadow-md);
	}

	.app-card[data-app="munseo"]:hover { border-color: var(--color-app-munseo); }
	.app-card[data-app="umbracast"]:hover { border-color: var(--color-app-umbracast); }
	.app-card[data-app="sincheong"]:hover { border-color: var(--color-app-sincheong); }

	.app-card-label {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: var(--space-2);
	}

	.app-card[data-app="munseo"] .app-card-label { color: var(--color-app-munseo); }
	.app-card[data-app="umbracast"] .app-card-label { color: var(--color-app-umbracast); }
	.app-card[data-app="sincheong"] .app-card-label { color: var(--color-app-sincheong); }

	.app-card-headline {
		font-family: var(--font-display);
		font-size: var(--font-size-h3);
		font-weight: var(--font-weight-light);
		margin-bottom: var(--space-2);
	}

	.app-card-desc {
		font-family: var(--font-body);
		font-size: var(--font-size-small);
		color: var(--color-text-2);
		margin-bottom: var(--space-3);
	}

	.app-card-domain {
		font-family: var(--font-mono);
		font-size: var(--font-size-caption);
		color: var(--color-text-3);
	}

	.app-card-arrow {
		font-family: var(--font-ui);
		font-size: var(--font-size-h2);
		font-weight: var(--font-weight-light);
		color: var(--color-text-3);
		flex-shrink: 0;
		transition: transform var(--dur-fast) var(--ease-smooth);
	}

	.app-card:hover .app-card-arrow {
		transform: translateX(var(--space-2));
		color: var(--color-text-1);
	}

	@media (max-width: 768px) {
		.app-card {
			padding: var(--space-6);
		}
	}
</style>
