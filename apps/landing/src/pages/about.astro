---
import Base from "../layouts/Base.astro";
import { STUDIO_APPS } from "../lib/apps";
---

<Base
	title="소개 — Modfolio Studio"
	description="좋은 도구는 진입장벽을 없앱니다. Studio가 만드는 크리에이티브 환경에 대하여."
>
	<main id="main">
		<section class="about-hero">
			<nav class="breadcrumb" aria-label="현재 위치">
				<a href="/">Studio</a> <span aria-hidden="true">→</span> <span>소개</span>
			</nav>
			<h1 class="about-title">
				만드는 사람 곁에<br />있는 도구.
			</h1>
		</section>

		<section class="mission">
			<div class="mission-inner">
				<div class="mission-block">
					<h2 class="mission-label">우리가 믿는 것</h2>
					<p class="mission-text">
						크리에이티브는 타고나는 것이 아닙니다. 좋은 환경과 적절한 도구가
						만나면, 누구든 만들 수 있습니다. Studio는 그 환경을 설계합니다.
					</p>
				</div>
				<div class="mission-block">
					<h2 class="mission-label">우리가 만드는 것</h2>
					<p class="mission-text">
						전문가만 다룰 수 있는 무거운 소프트웨어 대신, 브라우저를 열면 바로
						시작되는 가벼운 도구. 설치도, 학습 곡선도, 구독 피로도 없는
						크리에이티브 유틸리티를 만듭니다.
					</p>
				</div>
			</div>
		</section>

		<section class="values">
			<h2 class="section-heading">세 가지 원칙</h2>
			<div class="values-grid">
				<div class="value-card" data-accent="coral">
					<h3 class="value-title">열면 바로 시작</h3>
					<p class="value-desc">
						설치 과정도, 환경 설정도 필요 없습니다. URL을 열면 도구가 이미
						준비되어 있습니다.
					</p>
				</div>
				<div class="value-card" data-accent="amber">
					<h3 class="value-title">하나의 계정, 모든 도구</h3>
					<p class="value-desc">
						Modfolio Connect 계정 하나로 Studio의 모든 앱에 접근합니다. 앱마다
						다른 로그인은 없습니다.
					</p>
				</div>
				<div class="value-card" data-accent="violet">
					<h3 class="value-title">가볍지만 정확하게</h3>
					<p class="value-desc">
						Cloudflare Edge에서 실행됩니다. 가벼운 것은 도구이지, 결과물이
						아닙니다.
					</p>
				</div>
			</div>
		</section>

		<section class="about-apps">
			<h2 class="section-heading">Studio의 도구</h2>
			<div class="about-apps-grid">
				{
					STUDIO_APPS.map((app) => (
						<a
							href={`/apps/${app.id}`}
							class="about-app-card"
							data-app={app.id}
						>
							<h3 class="about-app-name">{app.name}</h3>
							<p class="about-app-headline">{app.headline}</p>
							<span class="about-app-domain">{app.domain}</span>
						</a>
					))
				}
			</div>
		</section>
	</main>
</Base>

<style>
	.about-hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 70vh;
		padding: var(--header-height) var(--layout-padding-x) var(--space-16);
		text-align: center;
	}

	.breadcrumb {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		color: var(--color-text-3);
		margin-bottom: var(--space-8);
	}

	.breadcrumb a:hover {
		color: var(--color-text-1);
	}

	.about-title {
		font-family: var(--font-display);
		font-size: var(--font-size-hero);
		font-weight: var(--font-weight-light);
		line-height: 1.15;
		letter-spacing: -0.03em;
	}

	.mission {
		max-width: var(--layout-max-width);
		margin: 0 auto;
		padding: var(--space-20) var(--layout-padding-x);
	}

	.mission-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-12);
	}

	.mission-block {
		padding: var(--space-8);
		border: 1px solid transparent;
		border-radius: var(--radius-lg);
		transition:
			border-color var(--dur-base) var(--ease-smooth),
			background var(--dur-base) var(--ease-smooth);
	}

	.mission-block:hover {
		border-color: var(--color-border-default);
		background: var(--color-surface-raised);
	}

	.mission-label {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-accent-primary);
		margin-bottom: var(--space-4);
	}

	.mission-text {
		font-family: var(--font-body);
		font-size: var(--font-size-body);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-2);
		line-height: 1.8;
		max-width: 50ch;
	}

	.section-heading {
		font-family: var(--font-display);
		font-size: var(--font-size-h2);
		font-weight: var(--font-weight-light);
		text-align: center;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-12);
	}

	.values {
		max-width: var(--layout-max-width);
		margin: 0 auto;
		padding: var(--space-20) var(--layout-padding-x);
	}

	.values-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-6);
	}

	.value-card {
		padding: var(--space-8);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-lg);
		transition:
			border-color var(--dur-base) var(--ease-smooth),
			transform var(--dur-fast) var(--ease-smooth);
	}

	.value-card:hover {
		transform: translateY(-3px);
	}

	.value-card[data-accent="coral"]:hover {
		border-color: var(--color-app-munseo);
	}
	.value-card[data-accent="amber"]:hover {
		border-color: var(--color-app-umbracast);
	}
	.value-card[data-accent="violet"]:hover {
		border-color: var(--color-app-sincheong);
	}

	.value-title {
		font-family: var(--font-display);
		font-size: var(--font-size-h3);
		font-weight: var(--font-weight-medium);
		margin-bottom: var(--space-3);
	}

	.value-desc {
		font-family: var(--font-body);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-2);
		line-height: 1.7;
		max-width: 40ch;
	}

	.about-apps {
		max-width: var(--layout-max-width);
		margin: 0 auto;
		padding: var(--space-20) var(--layout-padding-x);
	}

	.about-apps-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-6);
	}

	.about-app-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		padding: var(--space-8);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-lg);
		text-decoration: none;
		color: var(--color-text-1);
		transition:
			border-color var(--dur-base) var(--ease-smooth),
			transform var(--dur-fast) var(--ease-smooth),
			box-shadow var(--dur-base) var(--ease-smooth);
	}

	.about-app-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-md);
	}

	.about-app-card[data-app="munseo"]:hover {
		border-color: var(--color-app-munseo);
	}
	.about-app-card[data-app="umbracast"]:hover {
		border-color: var(--color-app-umbracast);
	}
	.about-app-card[data-app="sincheong"]:hover {
		border-color: var(--color-app-sincheong);
	}

	.about-app-name {
		font-family: var(--font-display);
		font-size: var(--font-size-h3);
		font-weight: var(--font-weight-bold);
	}

	.about-app-headline {
		font-family: var(--font-body);
		font-size: var(--font-size-small);
		color: var(--color-text-2);
	}

	.about-app-domain {
		font-family: var(--font-mono);
		font-size: var(--font-size-caption);
		color: var(--color-text-3);
	}

	@media (max-width: 768px) {
		.mission-inner {
			grid-template-columns: 1fr;
		}
		.values-grid {
			grid-template-columns: 1fr;
		}
		.about-apps-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
