---
import Base from "../layouts/Base.astro";

const faqs = [
	{
		q: "별도 계정이 필요한가요?",
		a: "아닙니다. Modfolio Connect 계정 하나면 Studio의 모든 앱에 접근할 수 있습니다. 별도 가입이나 추가 인증 없이 바로 사용 가능합니다.",
	},
	{
		q: "앱 간 데이터가 공유되나요?",
		a: "각 앱의 데이터는 완전히 분리됩니다. 인증 정보만 공유되며, 문서·오디오·폼 데이터는 개별 앱에서 독립 관리됩니다. Zero Physical Sharing 원칙을 따릅니다.",
	},
	{
		q: "무료로 사용할 수 있나요?",
		a: "현재 모든 기능을 무료로 제공합니다. 추후 고급 기능에 대한 유료 플랜이 추가될 수 있습니다.",
	},
	{
		q: "어떤 브라우저를 지원하나요?",
		a: "Chrome, Firefox, Safari, Edge 등 모든 최신 브라우저를 지원합니다. Cloudflare Edge에서 실행되므로 별도 설치 없이 브라우저만 있으면 됩니다.",
	},
	{
		q: "모바일에서도 사용 가능한가요?",
		a: "네, 모든 앱은 반응형으로 설계되어 모바일 브라우저에서도 동일한 기능을 제공합니다.",
	},
	{
		q: "Modfolio Studio와 다른 Modfolio 앱의 관계는?",
		a: "Modfolio Studio는 Modfolio 생태계의 크리에이티브 유틸리티 그룹입니다. Connect 계정으로 Studio뿐 아니라 Works, LS, Axiom 등 다른 그룹의 앱에도 접근할 수 있습니다.",
	},
];
---

<Base
	title="자주 묻는 질문 — Modfolio Studio"
	description="Studio 이용에 관한 자주 묻는 질문과 답변"
>
	<main>
		<section class="faq-hero">
			<h1 class="faq-title">자주 묻는 질문</h1>
		</section>

		<section class="faq-content">
			<div class="faq-list">
				{
					faqs.map((f) => (
						<details class="faq-item">
							<summary class="faq-q">{f.q}</summary>
							<p class="faq-a">{f.a}</p>
						</details>
					))
				}
			</div>
		</section>
	</main>
</Base>

<style>
	.faq-hero {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 40vh;
		padding: var(--header-height) var(--layout-padding-x) var(--space-8);
		text-align: center;
	}

	.faq-title {
		font-family: var(--font-display);
		font-size: var(--font-size-display);
		font-weight: var(--font-weight-light);
		letter-spacing: -0.03em;
	}

	.faq-content {
		max-width: 720px;
		margin: 0 auto;
		padding: 0 var(--layout-padding-x) var(--space-24);
	}

	.faq-list {
		display: flex;
		flex-direction: column;
	}

	.faq-item {
		border-bottom: 1px solid var(--color-border-default);
		transition: background var(--dur-fast) var(--ease-smooth);
	}

	.faq-item[open] {
		background: var(--color-surface-raised);
		border-left: 4px solid var(--color-accent-primary);
		padding-left: var(--space-4);
	}

	.faq-q {
		font-family: var(--font-ui);
		font-size: var(--font-size-body);
		font-weight: var(--font-weight-medium);
		padding: var(--space-6) 0;
		cursor: pointer;
		list-style: none;
		transition: color var(--dur-fast) var(--ease-smooth);
	}

	.faq-q::-webkit-details-marker {
		display: none;
	}

	.faq-q::before {
		content: "+";
		display: inline-block;
		width: var(--space-6);
		font-family: var(--font-mono);
		font-weight: var(--font-weight-light);
		font-size: var(--font-size-h3);
		color: var(--color-accent-primary);
		transition: transform var(--dur-fast) var(--ease-smooth);
	}

	.faq-item[open] .faq-q::before {
		transform: rotate(45deg);
	}

	.faq-q:hover {
		color: var(--color-accent-primary);
	}

	.faq-a {
		font-family: var(--font-body);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-2);
		line-height: 1.7;
		padding: 0 0 var(--space-6) var(--space-6);
		max-width: 55ch;
	}
</style>
