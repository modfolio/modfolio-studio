---
import Base from "../layouts/Base.astro";

const faqs = [
	{
		q: "계정을 따로 만들어야 하나요?",
		a: "아닙니다. Modfolio Connect 계정이 있다면 추가 가입 없이 Studio의 모든 앱을 바로 사용할 수 있습니다.",
	},
	{
		q: "앱끼리 데이터가 섞이지 않나요?",
		a: "각 앱의 데이터는 완전히 분리되어 있습니다. 공유되는 것은 로그인 인증뿐이며, 문서·오디오·폼 데이터는 각 앱에서 독립적으로 보관됩니다.",
	},
	{
		q: "비용이 드나요?",
		a: "현재 모든 기능을 무료로 이용할 수 있습니다. 향후 고급 기능에 대해 유료 플랜이 추가될 수 있지만, 기본 기능은 계속 무료입니다.",
	},
	{
		q: "어떤 환경에서 동작하나요?",
		a: "Chrome, Firefox, Safari, Edge 등 최신 브라우저라면 어디서든 동작합니다. 별도 소프트웨어 설치가 필요 없습니다.",
	},
	{
		q: "스마트폰에서도 쓸 수 있나요?",
		a: "네. 모든 앱이 반응형으로 설계되어 있어 모바일 브라우저에서도 동일하게 사용할 수 있습니다.",
	},
	{
		q: "Modfolio의 다른 서비스와는 어떤 관계인가요?",
		a: "Studio는 Modfolio 생태계의 크리에이티브 유틸리티 그룹입니다. 같은 Connect 계정으로 Works, LS, Axiom 등 다른 그룹의 서비스에도 접근할 수 있습니다.",
	},
];
---

<Base
	title="자주 묻는 질문 — Modfolio Studio"
	description="Studio 이용에 관한 자주 묻는 질문과 답변"
>
	<main id="main">
		<section class="faq-hero">
			<nav class="breadcrumb" aria-label="현재 위치">
				<a href="/">Studio</a> <span aria-hidden="true">→</span> <span>FAQ</span>
			</nav>
			<h1 class="faq-title">자주 묻는 질문</h1>
		</section>

		<section class="faq-content">
			<div class="faq-list">
				{
					faqs.map((f) => (
						<details class="faq-item">
							<summary class="faq-q">{f.q}</summary>
							<p class="faq-a">{f.a}</p>
						</details>
					))
				}
			</div>
		</section>
	</main>
</Base>

<style>
	.breadcrumb {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		color: var(--color-text-3);
		margin-bottom: var(--space-6);
	}

	.breadcrumb a:hover { color: var(--color-text-1); }

	.faq-hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 40vh;
		padding: var(--header-height) var(--layout-padding-x) var(--space-8);
		text-align: center;
	}

	.faq-title {
		font-family: var(--font-display);
		font-size: var(--font-size-display);
		font-weight: var(--font-weight-light);
		letter-spacing: -0.03em;
	}

	.faq-content {
		max-width: 720px;
		margin: 0 auto;
		padding: 0 var(--layout-padding-x) var(--space-24);
	}

	.faq-list {
		display: flex;
		flex-direction: column;
	}

	.faq-item {
		border-bottom: 1px solid var(--color-border-default);
		transition: background var(--dur-fast) var(--ease-smooth);
	}

	.faq-item[open] {
		background: var(--color-surface-raised);
		border-left: 4px solid var(--color-accent-primary);
		padding-left: var(--space-4);
	}

	.faq-q {
		font-family: var(--font-ui);
		font-size: var(--font-size-body);
		font-weight: var(--font-weight-medium);
		padding: var(--space-6) 0;
		cursor: pointer;
		list-style: none;
		transition: color var(--dur-fast) var(--ease-smooth);
	}

	.faq-q::-webkit-details-marker {
		display: none;
	}

	.faq-q::before {
		content: "+";
		display: inline-block;
		width: var(--space-6);
		font-family: var(--font-mono);
		font-weight: var(--font-weight-light);
		font-size: var(--font-size-h3);
		color: var(--color-accent-primary);
		transition: transform var(--dur-fast) var(--ease-smooth);
	}

	.faq-item[open] .faq-q::before {
		transform: rotate(45deg);
	}

	.faq-q:hover {
		color: var(--color-accent-primary);
	}

	.faq-a {
		font-family: var(--font-body);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-2);
		line-height: 1.7;
		padding: 0 0 var(--space-6) var(--space-6);
		max-width: 55ch;
	}
</style>
