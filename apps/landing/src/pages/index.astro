---
import Base from "../layouts/Base.astro";
import { STUDIO_APPS } from "../lib/apps";

const portalUrl = "https://lab.modfolio.io";

const principles = [
	{
		title: "형식을 가리지 않는다",
		desc: "글이든, 소리든, 데이터든. 표현하고 싶은 것이 있다면 형식은 Studio가 해결합니다.",
	},
	{
		title: "원본은 밖으로 나가지 않는다",
		desc: "파일은 디바이스 안에서 처리됩니다. 서버로 전송하지 않습니다. 당신의 표현은 당신의 것입니다.",
	},
	{
		title: "열면 바로 시작된다",
		desc: "설치도, 가입도, 대기도 없습니다. 브라우저를 열면 이미 준비되어 있습니다.",
	},
];
---

<Base
	title="Modfolio Studio — Creative Expression"
	description="표현되지 못한 것들에 형태를 부여합니다. Modfolio의 크리에이티브 그룹."
>
	<main id="main">
		<!-- ── Hero ── -->
		<section class="hero">
			<div class="hero-bg">
				<div class="hero-glow"></div>
				<div class="hero-grid-pattern"></div>
			</div>
			<div class="hero-content">
				<p class="hero-eyebrow">Modfolio Studio</p>
				<h1 class="hero-title">표현되지 못한 것들에<br />형태를 부여합니다.</h1>
			</div>
		</section>

		<!-- ── Manifesto ── -->
		<section class="manifesto" id="manifesto">
			<div class="manifesto-content">
				<p class="manifesto-line manifesto-lead">표현은 타고나는 것이 아닙니다.</p>
				<div class="manifesto-body">
					<p>누구에게나 말하고 싶은 것이 있고,<br />보여주고 싶은 것이 있고,<br />들려주고 싶은 것이 있습니다.</p>
					<p>부족한 건 재능이 아닙니다.<br />적절한 수단입니다.</p>
					<p>Studio는 그 수단을 만듭니다.<br />글로, 소리로, 데이터로 —<br />형식을 가리지 않고<br />생각이 형태를 갖출 수 있는 환경을.</p>
				</div>
			</div>
		</section>

		<div class="section-divider" aria-hidden="true"></div>

		<!-- ── Principles ── -->
		<section class="principles">
			<p class="section-eyebrow">Principles</p>
			<h2 class="section-heading">우리가 일하는 방식</h2>
			<div class="principles-grid">
				{principles.map((p, i) => (
					<div class="principle-card" data-idx={i}>
						<h3 class="principle-title">{p.title}</h3>
						<p class="principle-desc">{p.desc}</p>
					</div>
				))}
			</div>
		</section>

		<div class="section-divider" aria-hidden="true"></div>

		<!-- ── Works ── -->
		<section class="works">
			<p class="section-eyebrow">Works</p>
			<h2 class="section-heading">Studio의 시선이 닿은 곳</h2>
			<div class="works-grid">
				{STUDIO_APPS.map((app) => (
					<a href={`/apps/${app.id}`} class={`works-card works-${app.id}`}>
						<p class="works-label">{app.name}</p>
						<h3 class="works-headline">{app.headline}</h3>
						<p class="works-desc">{app.desc}</p>
						<span class="works-domain">{app.domain}</span>
					</a>
				))}
			</div>
		</section>

		<!-- ── Horizon ── -->
		<section class="horizon">
			<div class="horizon-glow"></div>
			<h2 class="horizon-title">표현은 계속됩니다.</h2>
			<a href={portalUrl} class="btn-filled">Open Lab</a>
		</section>
	</main>
</Base>

<style>
	/* ── Buttons ── */

	.btn-filled {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: var(--space-3) var(--space-8);
		font-family: var(--font-ui);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		color: var(--color-surface-0);
		background: var(--color-accent-primary);
		border: none;
		border-radius: var(--radius-full);
		transition: transform var(--dur-fast) var(--ease-smooth), box-shadow var(--dur-base) var(--ease-smooth);
	}
	.btn-filled:hover { transform: scale(1.03); box-shadow: 0 0 32px color-mix(in oklch, var(--color-accent-primary) 25%, transparent); }
	.btn-filled:active { transform: scale(0.97); }

	/* ── Hero ── */

	.hero { position: relative; display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: var(--header-height) var(--layout-padding-x) var(--space-16); overflow: hidden; }
	.hero-bg { position: absolute; inset: 0; pointer-events: none; }
	.hero-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 50% 40% at 50% 45%, color-mix(in oklch, var(--color-accent-primary) 10%, transparent), transparent); }
	.hero-grid-pattern { position: absolute; inset: 0; background: radial-gradient(circle, color-mix(in oklch, var(--color-border-default) 40%, transparent) 1px, transparent 1px); background-size: 40px 40px; opacity: 0.5; }
	.hero-content { position: relative; text-align: center; max-width: var(--layout-max-width-mid); }
	.hero-eyebrow { font-family: var(--font-ui); font-size: var(--font-size-caption); font-weight: var(--font-weight-medium); text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-accent-primary); margin-bottom: var(--space-4); }
	.hero-title { font-family: var(--font-display); font-size: var(--font-size-hero); font-weight: var(--font-weight-light); line-height: 1.15; letter-spacing: -0.03em; text-shadow: 0 4px 40px color-mix(in oklch, var(--color-accent-primary) 15%, transparent); }

	/* ── Manifesto ── */

	.manifesto { max-width: var(--layout-max-width-mid); margin: 0 auto; padding: var(--space-24) var(--layout-padding-x); }
	.manifesto-content { max-width: 640px; }
	.manifesto-lead { font-family: var(--font-display); font-size: var(--font-size-h1); font-weight: var(--font-weight-light); line-height: 1.3; letter-spacing: -0.02em; margin-bottom: var(--space-12); }
	.manifesto-body { display: flex; flex-direction: column; gap: var(--space-8); }
	.manifesto-body p { font-family: var(--font-body); font-size: var(--font-size-h3); font-weight: var(--font-weight-regular); line-height: 1.8; color: var(--color-text-2); }

	/* ── Shared Section Styles ── */

	.section-eyebrow { font-family: var(--font-ui); font-size: var(--font-size-caption); font-weight: var(--font-weight-medium); text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-accent-primary); text-align: center; margin-bottom: var(--space-4); }
	.section-heading { font-family: var(--font-display); font-size: var(--font-size-h2); font-weight: var(--font-weight-light); text-align: center; letter-spacing: -0.02em; margin-bottom: var(--space-12); }
	.section-divider { width: 48px; height: 1px; background: var(--color-border-default); margin: 0 auto; }

	/* ── Principles ── */

	.principles { max-width: var(--layout-max-width-mid); margin: 0 auto; padding: var(--space-24) var(--layout-padding-x); }
	.principles-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
	.principle-card { padding: var(--space-6) var(--space-8); border: 1px solid var(--color-border-default); border-radius: var(--radius-lg); transition: border-color var(--dur-base) var(--ease-smooth), background var(--dur-base) var(--ease-smooth); }
	.principle-card:hover { background: var(--color-surface-raised); border-color: var(--color-border-hover); }
	.principle-card[data-idx="0"]:hover { border-color: var(--color-app-munseo); }
	.principle-card[data-idx="1"]:hover { border-color: var(--color-app-umbracast); }
	.principle-card[data-idx="2"]:hover { border-color: var(--color-app-sincheong); }
	.principle-title { font-family: var(--font-display); font-size: var(--font-size-h3); font-weight: var(--font-weight-medium); margin-bottom: var(--space-3); }
	.principle-desc { font-family: var(--font-body); font-size: var(--font-size-small); font-weight: var(--font-weight-regular); color: var(--color-text-2); line-height: 1.7; }

	/* ── Works ── */

	.works { max-width: var(--layout-max-width-mid); margin: 0 auto; padding: var(--space-24) var(--layout-padding-x); }
	.works-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
	.works-card { display: flex; flex-direction: column; padding: var(--space-8); border: 1px solid var(--color-border-default); border-radius: var(--radius-lg); text-decoration: none; color: inherit; transition: border-color var(--dur-base) var(--ease-smooth), background var(--dur-base) var(--ease-smooth); }
	.works-card:hover { background: var(--color-surface-raised); border-color: var(--color-border-hover); }
	.works-munseo:hover { border-color: var(--color-app-munseo); }
	.works-umbracast:hover { border-color: var(--color-app-umbracast); }
	.works-sincheong:hover { border-color: var(--color-app-sincheong); }
	.works-label { font-family: var(--font-ui); font-size: var(--font-size-caption); font-weight: var(--font-weight-medium); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: var(--space-3); }
	.works-munseo .works-label { color: var(--color-app-munseo); }
	.works-umbracast .works-label { color: var(--color-app-umbracast); }
	.works-sincheong .works-label { color: var(--color-app-sincheong); }
	.works-headline { font-family: var(--font-display); font-size: var(--font-size-h3); font-weight: var(--font-weight-medium); margin-bottom: var(--space-2); }
	.works-desc { font-family: var(--font-body); font-size: var(--font-size-small); color: var(--color-text-3); margin-bottom: var(--space-6); flex-grow: 1; }
	.works-domain { font-family: var(--font-ui); font-size: var(--font-size-caption); color: var(--color-text-3); }

	/* ── Horizon ── */

	.horizon { position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 50vh; padding: var(--space-24) var(--layout-padding-x); text-align: center; overflow: hidden; }
	.horizon-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 30% 40% at 30% 50%, color-mix(in oklch, var(--color-app-munseo) 8%, transparent), transparent), radial-gradient(ellipse 30% 40% at 50% 60%, color-mix(in oklch, var(--color-app-umbracast) 8%, transparent), transparent), radial-gradient(ellipse 30% 40% at 70% 40%, color-mix(in oklch, var(--color-app-sincheong) 8%, transparent), transparent); pointer-events: none; }
	.horizon-title { position: relative; font-family: var(--font-display); font-size: var(--font-size-h1); font-weight: var(--font-weight-light); letter-spacing: -0.02em; margin-bottom: var(--space-8); }

	/* ── Responsive ── */

	@media (max-width: 768px) {
		.hero-title { font-size: clamp(2rem, 6vw, 3.5rem); }
		.manifesto-lead { font-size: var(--font-size-h2); }
		.manifesto-body p { font-size: var(--font-size-body); }
		.principles-grid { grid-template-columns: 1fr; }
		.works-grid { grid-template-columns: 1fr; }
	}
	@media (max-width: 480px) {
		.hero-title { font-size: clamp(1.75rem, 5vw, 2.5rem); }
	}
</style>
