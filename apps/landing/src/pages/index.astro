---
import Base from "../layouts/Base.astro";
import { STUDIO_APPS } from "../lib/apps";

const portalUrl = "https://lab.modfolio.io";

const steps = [
	{
		num: "01",
		title: "하나의 계정",
		desc: "Modfolio Connect 로그인 한 번이면 충분합니다.",
	},
	{
		num: "02",
		title: "세 가지 도구",
		desc: "문서, 오디오, 폼. 필요한 순간에 즉시 접근.",
	},
	{
		num: "03",
		title: "설치 없이 시작",
		desc: "브라우저에서 바로. Edge에서 실행됩니다.",
	},
];

const faqs = [
	{
		q: "별도 계정이 필요한가요?",
		a: "아닙니다. Modfolio Connect 계정 하나면 Studio의 모든 앱에 접근할 수 있습니다.",
	},
	{
		q: "앱 간 데이터가 공유되나요?",
		a: "각 앱의 데이터는 완전히 분리됩니다. 인증 정보만 공유되며, 문서·오디오·폼 데이터는 개별 앱에서 독립 관리됩니다.",
	},
	{
		q: "무료로 사용할 수 있나요?",
		a: "현재 모든 기능을 무료로 제공합니다. 추후 고급 기능에 대한 유료 플랜이 추가될 수 있습니다.",
	},
];
---

<Base
	title="Modfolio Studio — 누구든 크리에이터가 될 수 있는 도구"
	description="크리에이티브는 재능의 영역이 아닙니다. 문서 변환, 오디오 처리, 폼 관리 — 하나의 계정으로 시작하세요."
>
	<main>
		<!-- ── Hero (100vh) ── -->
		<section class="hero">
			<div class="hero-bg">
				<div class="hero-glow"></div>
				<div class="hero-grid-pattern"></div>
			</div>
			<div class="hero-content">
				<h1 class="hero-title">
					크리에이티브는<br />재능의 영역이 아닙니다.
				</h1>
				<a href={portalUrl} class="hero-cta">Studio Lab 열기</a>
			</div>
		</section>

		<!-- ── Social Proof ── -->
		<section class="proof">
			<div class="proof-inner">
				<span class="proof-item">Modfolio 생태계</span>
				<span class="proof-sep" aria-hidden="true">·</span>
				<span class="proof-item proof-highlight">15개 앱</span>
				<span class="proof-sep" aria-hidden="true">·</span>
				<span class="proof-item">Connect SSO</span>
				<span class="proof-sep" aria-hidden="true">·</span>
				<span class="proof-item">100% Edge Native</span>
			</div>
		</section>

		<!-- ── Philosophy ── -->
		<section class="philosophy">
			<div class="philosophy-grid">
				<div class="philosophy-block">
					<h2 class="philosophy-label">미션</h2>
					<p class="philosophy-text">
						크리에이티브가 더 중요해지는 시대에,<br />
						진입장벽을 낮추는 것이<br />
						우리의 목표입니다.
					</p>
				</div>
				<div class="philosophy-block philosophy-right">
					<h2 class="philosophy-label">비전</h2>
					<p class="philosophy-text">
						재능이 있어야만 가능하다는<br />
						구시대적 사고에서 벗어나,<br />
						누구든 크리에이티브에 도전할 수 있는<br />
						방법론과 환경, 커뮤니티를 제공합니다.
					</p>
				</div>
			</div>
			<div class="philosophy-cta">
				<a href="/about" class="philosophy-link">Studio 소개 →</a>
			</div>
		</section>

		<!-- ── App Sections (각 100vh, 비대칭 + 기하학) ── -->
		<div id="apps">
			<!-- Munseo: 좌정렬 + 겹친 사각형 -->
			<section class="app-section app-munseo" data-app="munseo">
				<div class="app-geo geo-rects">
					<div class="geo-rect geo-rect-1"></div>
					<div class="geo-rect geo-rect-2"></div>
				</div>
				<div class="app-inner app-align-left">
					<p class="app-label">Munseo</p>
					<h2 class="app-headline">형식에서 해방하다.</h2>
					<p class="app-desc">문서 변환 유틸리티</p>
					<div class="app-actions">
						<span class="app-domain">munseo.app</span>
						<a href="https://munseo.app" class="app-visit" target="_blank" rel="noopener">앱 방문 →</a>
					</div>
				</div>
			</section>

			<!-- Umbracast: 오프셋 센터 + 파형 -->
			<section class="app-section app-umbracast" data-app="umbracast">
				<div class="app-geo geo-wave">
					<div class="geo-wave-line"></div>
					<div class="geo-wave-line geo-wave-2"></div>
				</div>
				<div class="app-inner app-align-center-offset">
					<p class="app-label">Umbracast</p>
					<h2 class="app-headline">소리를 다루다.</h2>
					<p class="app-desc">오디오 변환 유틸리티</p>
					<div class="app-actions">
						<span class="app-domain">umbracast.com</span>
						<a href="https://umbracast.com" class="app-visit" target="_blank" rel="noopener">앱 방문 →</a>
					</div>
				</div>
			</section>

			<!-- Sincheong: 우정렬 + 원형 노드 -->
			<section class="app-section app-sincheong" data-app="sincheong">
				<div class="app-geo geo-nodes">
					<div class="geo-node geo-node-1"></div>
					<div class="geo-node geo-node-2"></div>
					<div class="geo-node geo-node-3"></div>
					<div class="geo-connector geo-conn-1"></div>
					<div class="geo-connector geo-conn-2"></div>
				</div>
				<div class="app-inner app-align-right">
					<p class="app-label">Sincheong</p>
					<h2 class="app-headline">수작업을 끝내다.</h2>
					<p class="app-desc">범용 폼 빌더</p>
					<div class="app-actions">
						<span class="app-domain">sincheong.app</span>
						<a href="https://sincheong.app" class="app-visit" target="_blank" rel="noopener">앱 방문 →</a>
					</div>
				</div>
			</section>
		</div>

		<!-- ── How It Works ── -->
		<section class="how">
			<h2 class="section-heading">5분이면 시작합니다</h2>
			<div class="steps">
				{steps.map((s, i) => (
					<div class="step" data-step={i}>
						<span class="step-num">{s.num}</span>
						<h3 class="step-title">{s.title}</h3>
						<p class="step-desc">{s.desc}</p>
					</div>
				))}
			</div>
		</section>

		<!-- ── FAQ ── -->
		<section class="faq" id="faq">
			<h2 class="section-heading">자주 묻는 질문</h2>
			<div class="faq-list">
				{faqs.map((f) => (
					<details class="faq-item">
						<summary class="faq-q">{f.q}</summary>
						<p class="faq-a">{f.a}</p>
					</details>
				))}
			</div>
		</section>

		<!-- ── Closing CTA ── -->
		<section class="closing">
			<div class="closing-glow"></div>
			<h2 class="closing-title">도구는 준비되었습니다.</h2>
			<a href={portalUrl} class="closing-cta">Studio Lab 열기</a>
		</section>
	</main>
</Base>

<style>
	/* ═══ Hero ═══ */

	.hero {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		padding: var(--header-height) var(--layout-padding-x) var(--space-16);
		overflow: hidden;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.hero-glow {
		position: absolute;
		inset: 0;
		background: radial-gradient(
			ellipse 50% 40% at 50% 45%,
			color-mix(in oklch, var(--color-accent-primary) 10%, transparent),
			transparent
		);
	}

	.hero-grid-pattern {
		position: absolute;
		inset: 0;
		background:
			repeating-linear-gradient(0deg, transparent, transparent 79px, color-mix(in oklch, var(--color-border-default) 30%, transparent) 80px),
			repeating-linear-gradient(90deg, transparent, transparent 79px, color-mix(in oklch, var(--color-border-default) 30%, transparent) 80px);
		opacity: 0.4;
	}

	.hero-content {
		position: relative;
		text-align: center;
		max-width: 900px;
	}

	.hero-title {
		font-family: var(--font-display);
		font-size: var(--font-size-hero);
		font-weight: var(--font-weight-light);
		line-height: 1.15;
		letter-spacing: -0.03em;
		margin-bottom: var(--space-12);
		text-shadow: 0 4px 40px color-mix(in oklch, var(--color-accent-primary) 15%, transparent);
	}

	.hero-cta {
		display: inline-block;
		font-family: var(--font-ui);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		color: var(--color-text-1);
		text-decoration: none;
		padding: var(--space-3) var(--space-8);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-full);
		transition:
			border-color var(--dur-base) var(--ease-smooth),
			transform var(--dur-fast) var(--ease-smooth),
			box-shadow var(--dur-base) var(--ease-smooth);
	}

	.hero-cta:hover {
		border-color: var(--color-accent-primary);
		transform: scale(1.03);
		box-shadow: 0 0 40px color-mix(in oklch, var(--color-accent-primary) 25%, transparent);
	}

	.hero-cta:active {
		transform: scale(0.97);
	}

	/* ═══ Philosophy ═══ */

	.philosophy {
		max-width: var(--layout-max-width);
		margin: 0 auto;
		padding: var(--space-24) var(--layout-padding-x);
	}

	.philosophy-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-16);
		margin-bottom: var(--space-12);
	}

	.philosophy-block {
		padding: var(--space-8);
		border: 1px solid transparent;
		border-radius: var(--radius-lg);
		transition:
			border-color var(--dur-base) var(--ease-smooth),
			background var(--dur-base) var(--ease-smooth);
	}

	.philosophy-block:hover {
		border-color: var(--color-border-default);
		background: var(--color-surface-raised);
	}

	.philosophy-label {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-accent-primary);
		margin-bottom: var(--space-6);
	}

	.philosophy-text {
		font-family: var(--font-display);
		font-size: var(--font-size-h3);
		font-weight: var(--font-weight-light);
		line-height: 1.6;
		color: var(--color-text-2);
	}

	.philosophy-right {
		text-align: right;
	}

	.philosophy-cta {
		text-align: center;
	}

	.philosophy-link {
		font-family: var(--font-ui);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		color: var(--color-text-2);
		text-decoration: none;
		padding: var(--space-2) var(--space-6);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-full);
		transition:
			color var(--dur-fast) var(--ease-smooth),
			border-color var(--dur-fast) var(--ease-smooth);
	}

	.philosophy-link:hover {
		color: var(--color-text-1);
		border-color: var(--color-text-1);
	}

	/* ═══ Social Proof ═══ */

	.proof {
		border-top: 1px solid var(--color-border-default);
		border-bottom: 1px solid var(--color-border-default);
		padding: var(--space-4) var(--layout-padding-x);
	}

	.proof-inner {
		max-width: var(--layout-max-width);
		margin: 0 auto;
		display: flex;
		justify-content: center;
		align-items: center;
		gap: var(--space-3);
	}

	.proof-item {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-3);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: var(--space-1) var(--space-3);
		border-radius: var(--radius-sm);
		background: color-mix(in oklch, var(--color-surface-overlay) 50%, transparent);
		transition:
			color var(--dur-fast) var(--ease-smooth),
			background var(--dur-fast) var(--ease-smooth);
	}

	.proof-item:hover {
		color: var(--color-text-1);
		background: var(--color-surface-emphasis);
	}

	.proof-highlight {
		font-family: var(--font-mono);
		color: var(--color-accent-primary);
	}

	.proof-sep {
		color: var(--color-border-default);
	}

	/* ═══ App Sections (100vh, 비대칭) ═══ */

	.app-section {
		position: relative;
		display: flex;
		align-items: center;
		min-height: 100vh;
		padding: var(--space-16) var(--layout-padding-x);
		overflow: hidden;
	}

	.app-inner {
		position: relative;
		z-index: 1;
		max-width: var(--layout-max-width);
		width: 100%;
		margin: 0 auto;
	}

	/* Scroll-driven fade-in */
	.app-inner {
		animation: fadeUp var(--dur-slow) var(--ease-smooth) both;
		animation-timeline: view();
		animation-range: entry 0% entry 40%;
	}

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(var(--space-8)); }
		to { opacity: 1; transform: translateY(0); }
	}

	@supports not (animation-timeline: view()) {
		.app-inner { opacity: 1; transform: none; animation: none; }
	}

	/* 정렬 변형 — 가장자리에서 충분히 떨어지도록 */
	.app-align-left { text-align: left; max-width: 560px; margin-left: var(--space-16); margin-right: auto; }
	.app-align-center-offset { text-align: center; max-width: 560px; margin-left: auto; margin-right: auto; }
	.app-align-right { text-align: right; max-width: 560px; margin-left: auto; margin-right: var(--space-16); }

	.app-label {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin-bottom: var(--space-4);
	}

	.app-headline {
		font-family: var(--font-display);
		font-size: var(--font-size-display);
		font-weight: var(--font-weight-light);
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-4);
		transition: text-shadow var(--dur-base) var(--ease-smooth);
	}

	.app-munseo .app-inner:hover .app-headline {
		text-shadow: 0 0 40px color-mix(in oklch, var(--color-app-munseo) 25%, transparent);
	}

	.app-umbracast .app-inner:hover .app-headline {
		text-shadow: 0 0 40px color-mix(in oklch, var(--color-app-umbracast) 25%, transparent);
	}

	.app-sincheong .app-inner:hover .app-headline {
		text-shadow: 0 0 40px color-mix(in oklch, var(--color-app-sincheong) 25%, transparent);
	}

	.app-desc {
		font-family: var(--font-ui);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-3);
		margin-bottom: var(--space-6);
	}

	.app-actions {
		display: flex;
		align-items: center;
		gap: var(--space-4);
	}

	.app-align-right .app-actions { justify-content: flex-end; }
	.app-align-center-offset .app-actions { justify-content: center; }

	.app-domain {
		font-family: var(--font-mono);
		font-size: var(--font-size-caption);
		color: var(--color-text-3);
	}

	.app-visit {
		font-family: var(--font-ui);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		text-decoration: none;
		padding: var(--space-2) var(--space-6);
		border-radius: var(--radius-full);
		transition:
			transform var(--dur-fast) var(--ease-smooth),
			box-shadow var(--dur-base) var(--ease-smooth);
	}

	.app-visit:hover {
		transform: scale(1.05);
	}

	.app-visit:active { transform: scale(0.95); }

	/* Per-app colors */
	.app-munseo .app-label { color: var(--color-app-munseo); }
	.app-umbracast .app-label { color: var(--color-app-umbracast); }
	.app-sincheong .app-label { color: var(--color-app-sincheong); }

	.app-munseo .app-visit {
		color: var(--color-surface-0);
		background: var(--color-app-munseo);
	}

	.app-munseo .app-visit:hover {
		box-shadow: 0 0 32px color-mix(in oklch, var(--color-app-munseo) 30%, transparent);
	}

	.app-umbracast .app-visit {
		color: var(--color-surface-0);
		background: var(--color-app-umbracast);
	}

	.app-umbracast .app-visit:hover {
		box-shadow: 0 0 32px color-mix(in oklch, var(--color-app-umbracast) 30%, transparent);
	}

	.app-sincheong .app-visit {
		color: var(--color-surface-0);
		background: var(--color-app-sincheong);
	}

	.app-sincheong .app-visit:hover {
		box-shadow: 0 0 32px color-mix(in oklch, var(--color-app-sincheong) 30%, transparent);
	}

	/* Per-app radial glow backgrounds */
	.app-munseo {
		background: radial-gradient(ellipse 60% 50% at 70% 50%, color-mix(in oklch, var(--color-app-munseo) 8%, transparent), var(--color-surface-0) 65%);
	}

	.app-umbracast {
		background: radial-gradient(ellipse 60% 50% at 50% 40%, color-mix(in oklch, var(--color-app-umbracast) 8%, transparent), var(--color-surface-0) 65%);
	}

	.app-sincheong {
		background: radial-gradient(ellipse 60% 50% at 30% 50%, color-mix(in oklch, var(--color-app-sincheong) 8%, transparent), var(--color-surface-0) 65%);
	}

	/* ═══ Geometric Shapes ═══ */

	.app-geo {
		position: absolute;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
	}

	/* Munseo: 겹친 사각형 (문서) */
	.geo-rect {
		position: absolute;
		border: 1px solid var(--color-app-munseo);
		border-radius: var(--radius-md);
		opacity: 0.1;
	}

	.geo-rect-1 { width: 200px; height: 260px; right: 15%; top: 20%; transform: rotate(-6deg); }
	.geo-rect-2 { width: 180px; height: 240px; right: 18%; top: 25%; transform: rotate(3deg); }

	/* Umbracast: 파형 (오디오) */
	.geo-wave-line {
		position: absolute;
		width: 100%;
		height: 1px;
		top: 30%;
		background: repeating-linear-gradient(
			90deg,
			transparent,
			transparent 20px,
			color-mix(in oklch, var(--color-app-umbracast) 15%, transparent) 20px,
			color-mix(in oklch, var(--color-app-umbracast) 15%, transparent) 22px
		);
	}

	.geo-wave-2 { top: 70%; opacity: 0.5; }

	/* Sincheong: 원형 노드 (폼 연결) */
	.geo-node {
		position: absolute;
		border: 1px solid var(--color-app-sincheong);
		border-radius: var(--radius-full);
		opacity: 0.12;
	}

	.geo-node-1 { width: 40px; height: 40px; left: 12%; top: 30%; }
	.geo-node-2 { width: 32px; height: 32px; left: 8%; top: 50%; }
	.geo-node-3 { width: 24px; height: 24px; left: 18%; top: 55%; }

	.geo-connector {
		position: absolute;
		height: 1px;
		background: var(--color-app-sincheong);
		opacity: 0.08;
		transform-origin: left center;
	}

	.geo-conn-1 { width: 80px; left: calc(12% + 20px); top: calc(30% + 20px); transform: rotate(40deg); }
	.geo-conn-2 { width: 60px; left: calc(8% + 16px); top: calc(50% + 16px); transform: rotate(-20deg); }

	/* ═══ Section Heading ═══ */

	.section-heading {
		font-family: var(--font-display);
		font-size: var(--font-size-h2);
		font-weight: var(--font-weight-light);
		text-align: center;
