---
import Base from "../layouts/Base.astro";
import { STUDIO_APPS } from "../lib/apps";

const portalUrl = "https://lab.modfolio.io";

const steps = [
	{
		num: "01",
		title: "계정 하나면 됩니다",
		desc: "Modfolio Connect로 로그인하세요. 추가 가입 없이 모든 Studio 도구에 접근할 수 있습니다.",
	},
	{
		num: "02",
		title: "필요한 도구를 고르세요",
		desc: "문서, 오디오, 폼. 각각의 도구가 독립적으로 동작하면서도 하나의 워크플로우 안에 있습니다.",
	},
	{
		num: "03",
		title: "열면 바로 시작",
		desc: "설치할 것도, 기다릴 것도 없습니다. 브라우저를 열면 이미 준비되어 있습니다.",
	},
];

const faqs = [
	{
		q: "별도로 계정을 만들어야 하나요?",
		a: "아닙니다. Modfolio Connect 계정이 있다면 Studio의 모든 앱을 바로 사용할 수 있습니다. 별도 가입 절차가 없습니다.",
	},
	{
		q: "앱끼리 데이터가 공유되나요?",
		a: "아닙니다. 각 앱의 데이터는 완전히 분리되어 있습니다. 공유되는 것은 로그인 정보뿐이며, 문서·오디오·폼 데이터는 각 앱에서 독립적으로 관리됩니다.",
	},
	{
		q: "비용이 드나요?",
		a: "현재 모든 기능을 무료로 이용할 수 있습니다. 추후 고급 기능에 한해 유료 플랜이 추가될 수 있습니다.",
	},
];
---

<Base
	title="Modfolio Studio — 만드는 사람을 위한 도구"
	description="좋은 도구는 진입장벽을 없앱니다. 문서, 오디오, 폼 — 전문가가 아니어도 시작할 수 있습니다."
>
	<main id="main">
		<!-- ── Hero (100vh) ── -->
		<section class="hero">
			<div class="hero-bg">
				<div class="hero-glow"></div>
				<div class="hero-grid-pattern"></div>
			</div>
			<div class="hero-content">
				<h1 class="hero-title">
					좋은 도구 앞에서,<br />모두가 크리에이터입니다.
				</h1>
				<a href={portalUrl} class="btn-outline">Studio Lab 열기</a>
			</div>
		</section>

		<!-- ── Social Proof ── -->
		<section class="proof">
			<div class="proof-inner">
				<span class="proof-item">Modfolio 생태계</span>
				<span class="proof-sep" aria-hidden="true">·</span>
				<span class="proof-item proof-highlight">15개 앱</span>
				<span class="proof-sep" aria-hidden="true">·</span>
				<span class="proof-item">Connect SSO</span>
				<span class="proof-sep" aria-hidden="true">·</span>
				<span class="proof-item">100% Edge Native</span>
			</div>
		</section>

		<!-- ── Philosophy ── -->
		<section class="philosophy">
			<div class="philosophy-grid">
				<div class="philosophy-block">
					<h2 class="philosophy-label">우리가 믿는 것</h2>
					<p class="philosophy-text">
						만들고 싶은 마음이 있다면,<br />
						그것으로 충분합니다.<br />
						나머지는 도구가 해결할 문제입니다.
					</p>
				</div>
				<div class="philosophy-block philosophy-right">
					<h2 class="philosophy-label">우리가 만드는 것</h2>
					<p class="philosophy-text">
						전문가만 쓸 수 있는 도구가 아닌,<br />
						누구든 열면 바로 시작할 수 있는<br />
						가볍고 정확한 크리에이티브 환경.
					</p>
				</div>
			</div>
			<div class="philosophy-cta">
				<a href="/about" class="btn-outline">Studio 소개 →</a>
			</div>
		</section>

		<!-- ── App Sections (각 100vh, 비대칭 + 기하학) ── -->
		<div id="apps">
			<!-- Munseo: 좌정렬 + 겹친 사각형 -->
			<section class="app-section app-munseo" data-app="munseo">
				<div class="app-geo geo-rects">
					<div class="geo-rect geo-rect-1"></div>
					<div class="geo-rect geo-rect-2"></div>
				</div>
				<div class="app-inner app-align-left">
					<p class="app-label">Munseo</p>
					<h2 class="app-headline">형식에서 해방하다.</h2>
					<p class="app-desc">문서 변환 유틸리티</p>
					<div class="app-actions">
						<a href="/apps/munseo" class="btn-outline">자세히 보기</a>
						<a href="https://munseo.app" class="btn-filled" target="_blank" rel="noopener" aria-label="Munseo 앱 방문">앱 방문 →</a>
					</div>
				</div>
			</section>

			<!-- Umbracast: 오프셋 센터 + 파형 -->
			<section class="app-section app-umbracast" data-app="umbracast">
				<div class="app-geo geo-wave">
					<div class="geo-wave-line"></div>
					<div class="geo-wave-line geo-wave-2"></div>
				</div>
				<div class="app-inner app-align-center-offset">
					<p class="app-label">Umbracast</p>
					<h2 class="app-headline">소리를 다루다.</h2>
					<p class="app-desc">오디오 변환 유틸리티</p>
					<div class="app-actions">
						<a href="/apps/umbracast" class="btn-outline">자세히 보기</a>
						<a href="https://umbracast.com" class="btn-filled" target="_blank" rel="noopener" aria-label="Umbracast 앱 방문">앱 방문 →</a>
					</div>
				</div>
			</section>

			<!-- Sincheong: 우정렬 + 원형 노드 -->
			<section class="app-section app-sincheong" data-app="sincheong">
				<div class="app-geo geo-nodes">
					<div class="geo-node geo-node-1"></div>
					<div class="geo-node geo-node-2"></div>
					<div class="geo-node geo-node-3"></div>
					<div class="geo-connector geo-conn-1"></div>
					<div class="geo-connector geo-conn-2"></div>
				</div>
				<div class="app-inner app-align-right">
					<p class="app-label">Sincheong</p>
					<h2 class="app-headline">수작업을 끝내다.</h2>
					<p class="app-desc">범용 폼 빌더</p>
					<div class="app-actions">
						<a href="/apps/sincheong" class="btn-outline">자세히 보기</a>
						<a href="https://sincheong.app" class="btn-filled" target="_blank" rel="noopener" aria-label="Sincheong 앱 방문">앱 방문 →</a>
					</div>
				</div>
			</section>
		</div>

		<!-- ── How It Works ── -->
		<section class="how">
			<h2 class="section-heading">시작하는 데 5분이면 됩니다</h2>
			<div class="steps">
				{steps.map((s, i) => (
					<div class="step" data-step={i}>
						<span class="step-num">{s.num}</span>
						<h3 class="step-title">{s.title}</h3>
						<p class="step-desc">{s.desc}</p>
					</div>
				))}
			</div>
		</section>

		<!-- ── FAQ ── -->
		<section class="faq" id="faq">
			<h2 class="section-heading">자주 묻는 질문</h2>
			<div class="faq-list">
				{faqs.map((f) => (
					<details class="faq-item">
						<summary class="faq-q">{f.q}</summary>
						<p class="faq-a">{f.a}</p>
					</details>
				))}
			</div>
		</section>

		<!-- ── Closing CTA ── -->
		<section class="closing">
			<div class="closing-glow"></div>
			<h2 class="closing-title">만들 준비가 되셨다면.</h2>
			<a href={portalUrl} class="btn-filled">Studio Lab 열기</a>
		</section>
	</main>
</Base>

<style>
	/* ═══════════════════════════════════════
	   CSS 전면 재작성 — 통일된 시스템
	   버튼: btn-outline / btn-filled
	   섹션: 통일 padding var(--space-24)
	   정렬: grid 기반 (margin 하드코딩 제거)
	   ═══════════════════════════════════════ */

	/* ── 버튼 시스템 (2종류) ── */

	.btn-outline {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: var(--space-3) var(--space-6);
		font-family: var(--font-ui);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		color: var(--color-text-2);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-full);
		transition:
			color var(--dur-fast) var(--ease-smooth),
			border-color var(--dur-fast) var(--ease-smooth),
			transform var(--dur-fast) var(--ease-smooth),
			box-shadow var(--dur-base) var(--ease-smooth);
	}

	.btn-outline:hover {
		color: var(--color-text-1);
		border-color: var(--color-text-1);
	}

	.btn-outline:active { transform: scale(0.97); }

	.btn-filled {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: var(--space-3) var(--space-8);
		font-family: var(--font-ui);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		color: var(--color-surface-0);
		background: var(--color-accent-primary);
		border: none;
		border-radius: var(--radius-full);
		transition:
			transform var(--dur-fast) var(--ease-smooth),
			box-shadow var(--dur-base) var(--ease-smooth);
	}

	.btn-filled:hover {
		transform: scale(1.03);
		box-shadow: 0 0 32px color-mix(in oklch, var(--color-accent-primary) 25%, transparent);
	}

	.btn-filled:active { transform: scale(0.97); }

	/* ── Hero ── */

	.hero {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		padding: var(--header-height) var(--layout-padding-x) var(--space-16);
		overflow: hidden;
	}

	.hero-bg { position: absolute; inset: 0; pointer-events: none; }

	.hero-glow {
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse 50% 40% at 50% 45%, color-mix(in oklch, var(--color-accent-primary) 10%, transparent), transparent);
	}

	.hero-grid-pattern {
		position: absolute;
		inset: 0;
		background:
			repeating-linear-gradient(0deg, transparent, transparent 79px, color-mix(in oklch, var(--color-border-default) 30%, transparent) 80px),
			repeating-linear-gradient(90deg, transparent, transparent 79px, color-mix(in oklch, var(--color-border-default) 30%, transparent) 80px);
		opacity: 0.4;
	}

	.hero-content {
		position: relative;
		text-align: center;
		max-width: var(--layout-max-width-mid);
	}

	.hero-title {
		font-family: var(--font-display);
		font-size: var(--font-size-hero);
		font-weight: var(--font-weight-light);
		line-height: 1.15;
		letter-spacing: -0.03em;
		margin-bottom: var(--space-12);
		text-shadow: 0 4px 40px color-mix(in oklch, var(--color-accent-primary) 15%, transparent);
	}

	/* ── Social Proof ── */

	.proof {
		border-top: 1px solid var(--color-border-default);
		border-bottom: 1px solid var(--color-border-default);
		padding: var(--space-6) var(--layout-padding-x);
	}

	.proof-inner {
		max-width: var(--layout-max-width);
		margin: 0 auto;
		display: flex;
		justify-content: center;
		align-items: center;
		gap: var(--space-4);
	}

	.proof-item {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-3);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: var(--space-2) var(--space-4);
		border-radius: var(--radius-sm);
		background: var(--color-surface-raised);
		transition: color var(--dur-fast) var(--ease-smooth), background var(--dur-fast) var(--ease-smooth);
	}

	.proof-item:hover { color: var(--color-text-1); background: var(--color-surface-emphasis); }
	.proof-highlight { font-family: var(--font-mono); color: var(--color-accent-primary); }
	.proof-sep { color: var(--color-border-default); }

	/* ── Philosophy ── */

	.philosophy {
		max-width: var(--layout-max-width-mid);
		margin: 0 auto;
		padding: var(--space-24) var(--layout-padding-x);
	}

	.philosophy-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-8);
		margin-bottom: var(--space-12);
	}

	.philosophy-block {
		padding: var(--space-8);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-lg);
		transition: background var(--dur-base) var(--ease-smooth), border-color var(--dur-base) var(--ease-smooth);
	}

	.philosophy-block:hover {
		background: var(--color-surface-raised);
		border-color: var(--color-border-hover);
	}

	.philosophy-label {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-accent-primary);
		margin-bottom: var(--space-4);
	}

	.philosophy-text {
		font-family: var(--font-body);
		font-size: var(--font-size-body);
		font-weight: var(--font-weight-regular);
		line-height: 1.8;
		color: var(--color-text-2);
	}

	.philosophy-cta { text-align: center; }

	/* ── App Sections ── */

	.app-section {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 85vh;
		padding: var(--space-24) var(--layout-padding-x);
		overflow: hidden;
	}

	.app-inner {
		position: relative;
		z-index: 1;
		max-width: var(--layout-max-width);
		width: 100%;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: center;
		gap: var(--space-12);
		animation: fadeUp var(--dur-slow) var(--ease-smooth) both;
		animation-timeline: view();
		animation-range: entry 0% entry 40%;
	}

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(var(--space-8)); }
		to { opacity: 1; transform: translateY(0); }
	}

	@supports not (animation-timeline: view()) {
		.app-inner { opacity: 1; transform: none; animation: none; }
	}

	/* Munseo: 콘텐츠 좌, 기하학 우 */
	.app-align-left { grid-column: 1; }

	/* Umbracast: 콘텐츠 센터 (full span) */
	.app-align-center-offset { grid-column: 1 / -1; text-align: center; max-width: 640px; margin: 0 auto; }

	/* Sincheong: 콘텐츠 우, 기하학 좌 */
	.app-align-right { grid-column: 2; text-align: right; }

	.app-label {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin-bottom: var(--space-4);
	}

	.app-headline {
		font-family: var(--font-display);
		font-size: var(--font-size-display);
		font-weight: var(--font-weight-light);
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-4);
		transition: text-shadow var(--dur-base) var(--ease-smooth);
	}

	.app-munseo .app-inner:hover .app-headline { text-shadow: 0 0 40px color-mix(in oklch, var(--color-app-munseo) 25%, transparent); }
	.app-umbracast .app-inner:hover .app-headline { text-shadow: 0 0 40px color-mix(in oklch, var(--color-app-umbracast) 25%, transparent); }
	.app-sincheong .app-inner:hover .app-headline { text-shadow: 0 0 40px color-mix(in oklch, var(--color-app-sincheong) 25%, transparent); }

	.app-desc {
		font-family: var(--font-ui);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-3);
		margin-bottom: var(--space-6);
	}

	.app-actions { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
	.app-align-right .app-actions { justify-content: flex-end; }
	.app-align-center-offset .app-actions { justify-content: center; }

	/* Per-app colors */
	.app-munseo .app-label { color: var(--color-app-munseo); }
	.app-umbracast .app-label { color: var(--color-app-umbracast); }
	.app-sincheong .app-label { color: var(--color-app-sincheong); }

	.app-munseo .btn-filled { background: var(--color-app-munseo); }
	.app-munseo .btn-filled:hover { box-shadow: 0 0 32px color-mix(in oklch, var(--color-app-munseo) 30%, transparent); }
	.app-umbracast .btn-filled { background: var(--color-app-umbracast); }
	.app-umbracast .btn-filled:hover { box-shadow: 0 0 32px color-mix(in oklch, var(--color-app-umbracast) 30%, transparent); }
	.app-sincheong .btn-filled { background: var(--color-app-sincheong); }
	.app-sincheong .btn-filled:hover { box-shadow: 0 0 32px color-mix(in oklch, var(--color-app-sincheong) 30%, transparent); }

	/* Per-app glow backgrounds */
	.app-munseo { background: radial-gradient(ellipse 60% 50% at 70% 50%, color-mix(in oklch, var(--color-app-munseo) 8%, transparent), var(--color-surface-0) 65%); }
	.app-umbracast { background: radial-gradient(ellipse 60% 50% at 50% 40%, color-mix(in oklch, var(--color-app-umbracast) 8%, transparent), var(--color-surface-0) 65%); }
	.app-sincheong { background: radial-gradient(ellipse 60% 50% at 30% 50%, color-mix(in oklch, var(--color-app-sincheong) 8%, transparent), var(--color-surface-0) 65%); }

	/* ── Geometric Shapes ── */

	.app-geo { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }

	.geo-rect { position: absolute; border: 1px solid var(--color-app-munseo); border-radius: var(--radius-md); opacity: 0.1; }
	.geo-rect-1 { width: 200px; height: 260px; right: 15%; top: 20%; transform: rotate(-6deg); }
	.geo-rect-2 { width: 180px; height: 240px; right: 18%; top: 25%; transform: rotate(3deg); }

	.geo-wave-line { position: absolute; width: 100%; height: 1px; top: 30%; background: repeating-linear-gradient(90deg, transparent, transparent 20px, color-mix(in oklch, var(--color-app-umbracast) 15%, transparent) 20px, color-mix(in oklch, var(--color-app-umbracast) 15%, transparent) 22px); }
	.geo-wave-2 { top: 70%; opacity: 0.5; }

	.geo-node { position: absolute; border: 1px solid var(--color-app-sincheong); border-radius: var(--radius-full); opacity: 0.12; }
	.geo-node-1 { width: 40px; height: 40px; left: 12%; top: 30%; }
	.geo-node-2 { width: 32px; height: 32px; left: 8%; top: 50%; }
	.geo-node-3 { width: 24px; height: 24px; left: 18%; top: 55%; }

	.geo-connector { position: absolute; height: 1px; background: var(--color-app-sincheong); opacity: 0.08; transform-origin: left center; }
	.geo-conn-1 { width: 80px; left: calc(12% + 20px); top: calc(30% + 20px); transform: rotate(40deg); }
	.geo-conn-2 { width: 60px; left: calc(8% + 16px); top: calc(50% + 16px); transform: rotate(-20deg); }

	/* ── Section Heading ── */

	.section-heading {
		font-family: var(--font-display);
		font-size: var(--font-size-h2);
		font-weight: var(--font-weight-light);
		text-align: center;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-12);
	}

	/* ── How It Works ── */

	.how {
		max-width: var(--layout-max-width-mid);
		margin: 0 auto;
		padding: var(--space-24) var(--layout-padding-x);
	}

	.steps {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-6);
	}

	.step {
		padding: var(--space-6) var(--space-8);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-lg);
