---
import Base from "../layouts/Base.astro";
import { STUDIO_APPS } from "../lib/apps";

const portalUrl = "https://lab.modfolio.io";
---

<Base
	title="Modfolio Studio"
	description="엔터테인먼트 & 유틸리티 그룹 — Munseo, Umbracast, Sincheong"
>
	<main class="landing">
		<div class="glow glow-1" />
		<div class="glow glow-2" />

		<section class="hero">
			<div class="hero-content">
				<p class="hero-eyebrow">Entertainment & Utility Group</p>
				<h1 class="hero-title">
					흩어진 도구를,
					<br />
					하나의 스튜디오로.
				</h1>
				<p class="hero-body">
					문서 변환, 오디오 처리, 폼 관리 — 매번 다른 도구, 다른 계정, 다른
					워크플로우. Modfolio Studio는 하나의 SSO 로그인으로 세 가지
					유틸리티에 즉시 접근합니다.
				</p>
				<a href={portalUrl} class="btn-cta"> Studio Lab 열기 </a>
			</div>

			<div class="hero-apps">
				{
					STUDIO_APPS.map((app, i) => (
						<div
							class="app-preview"
							data-app={app.id}
							style={`--stagger: ${i}`}
						>
							<span class="app-preview-name">{app.name}</span>
							<span class="app-preview-desc">{app.desc}</span>
						</div>
					))
				}
			</div>
		</section>

		<section class="features">
			{
				STUDIO_APPS.map((app) => (
					<div class="feature-card" data-app={app.id}>
						<h3 class="feature-name">{app.name}</h3>
						<p class="feature-tagline">{app.tagline}</p>
						<span class="feature-domain">{app.domain}</span>
					</div>
				))
			}
		</section>

		<section class="cta-section">
			<h2 class="cta-heading">하나의 계정, 세 가지 도구</h2>
			<p class="cta-body">
				Modfolio Connect 계정 하나로 Studio의 모든 유틸리티를 사용하세요.
			</p>
			<a href={portalUrl} class="btn-cta"> 시작하기 </a>
		</section>
	</main>
</Base>

<style>
	body {
		font-family: var(--font-body);
		background: var(--color-surface-0);
		color: var(--color-text-1);
		min-height: 100vh;
		line-height: 1.6;
	}

	.landing {
		position: relative;
		overflow: hidden;
	}

	.glow {
		position: fixed;
		width: 600px;
		height: 600px;
		border-radius: 50%;
		filter: blur(120px);
		opacity: 0.05;
		pointer-events: none;
	}

	.glow-1 {
		background: var(--color-accent-primary);
		top: -200px;
		right: -200px;
	}

	.glow-2 {
		background: var(--color-accent-secondary);
		bottom: -200px;
		left: -200px;
	}

	.hero {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: var(--space-12);
		align-items: center;
		min-height: 100vh;
		max-width: 1120px;
		margin: 0 auto;
		padding: var(--space-12) var(--space-6);
		position: relative;
		z-index: 1;
	}

	.hero-eyebrow {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-accent-primary);
		margin-bottom: var(--space-4);
	}

	.hero-title {
		font-family: var(--font-display);
		font-size: var(--font-size-display);
		font-weight: 700;
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-6);
	}

	.hero-body {
		font-family: var(--font-body);
		font-size: var(--font-size-body);
		color: var(--color-text-2);
		max-width: 48ch;
		margin-bottom: var(--space-8);
		line-height: 1.7;
	}

	.hero-apps {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	.app-preview {
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
		padding: var(--space-4) var(--space-6);
		border-left: 2px solid var(--color-border-default);
		margin-left: calc(var(--stagger) * var(--space-8));
		transition: border-color var(--dur-base) var(--ease-smooth);
	}

	.app-preview[data-app="munseo"] {
		border-color: var(--color-app-munseo);
	}

	.app-preview[data-app="umbracast"] {
		border-color: var(--color-app-umbracast);
	}

	.app-preview[data-app="sincheong"] {
		border-color: var(--color-app-sincheong);
	}

	.app-preview-name {
		font-family: var(--font-display);
		font-size: var(--font-size-h3);
		font-weight: 700;
	}

	.app-preview-desc {
		font-family: var(--font-ui);
		font-size: var(--font-size-small);
		color: var(--color-text-2);
	}

	.btn-cta {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-3) var(--space-8);
		background: var(--color-interactive-primary);
		border: none;
		border-radius: var(--radius-md);
		color: var(--color-surface-0);
		font-family: var(--font-ui);
		font-size: var(--font-size-body);
		font-weight: 700;
		text-decoration: none;
		cursor: pointer;
		transition: background var(--dur-fast) var(--ease-smooth);
	}

	.btn-cta:hover {
		background: var(--color-interactive-hover);
	}

	.features {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-6);
		max-width: 1120px;
		margin: 0 auto;
		padding: var(--space-16) var(--space-6);
		position: relative;
		z-index: 1;
	}

	.feature-card {
		padding: var(--space-8);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-lg);
		background: var(--color-surface-raised);
		transition:
			border-color var(--dur-base) var(--ease-smooth),
			transform var(--dur-fast) var(--ease-smooth);
	}

	.feature-card:hover {
		transform: translateY(-2px);
		border-color: var(--color-border-hover);
	}

	.feature-card[data-app="munseo"]:hover {
		border-color: var(--color-app-munseo);
	}

	.feature-card[data-app="umbracast"]:hover {
		border-color: var(--color-app-umbracast);
	}

	.feature-card[data-app="sincheong"]:hover {
		border-color: var(--color-app-sincheong);
	}

	.feature-name {
		font-family: var(--font-display);
		font-size: var(--font-size-h3);
		font-weight: 700;
		margin-bottom: var(--space-3);
	}

	.feature-tagline {
		font-family: var(--font-body);
		font-size: var(--font-size-small);
		color: var(--color-text-2);
		line-height: 1.6;
		margin-bottom: var(--space-6);
	}

	.feature-domain {
		font-family: var(--font-mono);
		font-size: var(--font-size-caption);
		color: var(--color-text-3);
	}

	.cta-section {
		text-align: center;
		padding: var(--space-20) var(--space-6);
		position: relative;
		z-index: 1;
	}

	.cta-heading {
		font-family: var(--font-display);
		font-size: var(--font-size-h1);
		font-weight: 700;
		margin-bottom: var(--space-4);
	}

	.cta-body {
		font-family: var(--font-body);
		font-size: var(--font-size-body);
		color: var(--color-text-2);
		margin-bottom: var(--space-8);
	}

	@media (max-width: 768px) {
		.hero {
			grid-template-columns: 1fr;
			min-height: auto;
			padding: var(--space-16) var(--space-4) var(--space-10);
		}

		.hero-apps {
			margin-top: var(--space-8);
		}

		.features {
			grid-template-columns: 1fr;
			padding: var(--space-10) var(--space-4);
		}
	}
</style>
