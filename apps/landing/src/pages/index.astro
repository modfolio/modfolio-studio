---
import Base from "../layouts/Base.astro";
import { STUDIO_APPS } from "../lib/apps";

const portalUrl = "https://lab.modfolio.io";

const steps = [
	{
		num: "01",
		title: "하나의 계정",
		desc: "Modfolio Connect 로그인 한 번이면 충분합니다.",
	},
	{
		num: "02",
		title: "세 가지 도구",
		desc: "문서, 오디오, 폼. 필요한 순간에 즉시 접근.",
	},
	{
		num: "03",
		title: "설치 없이 시작",
		desc: "브라우저에서 바로. Edge에서 실행됩니다.",
	},
];

const faqs = [
	{
		q: "별도 계정이 필요한가요?",
		a: "아닙니다. Modfolio Connect 계정 하나면 Studio의 모든 앱에 접근할 수 있습니다.",
	},
	{
		q: "앱 간 데이터가 공유되나요?",
		a: "각 앱의 데이터는 완전히 분리됩니다. 인증 정보만 공유되며, 문서·오디오·폼 데이터는 개별 앱에서 독립 관리됩니다.",
	},
	{
		q: "무료로 사용할 수 있나요?",
		a: "현재 모든 기능을 무료로 제공합니다. 추후 고급 기능에 대한 유료 플랜이 추가될 수 있습니다.",
	},
];
---

<Base
	title="Modfolio Studio — 누구든 크리에이터가 될 수 있는 도구"
	description="크리에이티브는 재능의 영역이 아닙니다. 문서 변환, 오디오 처리, 폼 관리 — 하나의 계정으로 시작하세요."
>
	<!-- ── Nav ── -->
	<nav class="nav">
		<div class="nav-inner">
			<a href="/" class="nav-logo">Studio</a>
			<a href={portalUrl} class="nav-cta">Lab 열기</a>
		</div>
	</nav>

	<main>
		<!-- ── Hero (100vh) ── -->
		<section class="hero">
			<div class="hero-glow"></div>
			<div class="hero-content">
				<h1 class="hero-title">
					크리에이티브는<br />재능의 영역이 아닙니다.
				</h1>
				<a href={portalUrl} class="hero-cta">Studio Lab 열기</a>
			</div>
		</section>

		<!-- ── Social Proof ── -->
		<section class="proof">
			<span>Modfolio 생태계</span>
			<span class="proof-sep" aria-hidden="true">·</span>
			<span>15개 앱</span>
			<span class="proof-sep" aria-hidden="true">·</span>
			<span>Connect SSO 통합</span>
			<span class="proof-sep" aria-hidden="true">·</span>
			<span>100% Edge Native</span>
		</section>

		<!-- ── App Sections (각 100vh) ── -->
		{
			STUDIO_APPS.map((app) => (
				<section class="app-section" data-app={app.id}>
					<div class="app-section-content">
						<p class="app-label">{app.name}</p>
						<h2 class="app-headline">{app.headline}</h2>
						<p class="app-desc">
							{app.desc} · {app.domain}
						</p>
					</div>
				</section>
			))
		}

		<!-- ── How It Works ── -->
		<section class="how">
			<h2 class="section-heading">5분이면 시작합니다</h2>
			<div class="steps">
				{
					steps.map((s) => (
						<div class="step">
							<span class="step-num">{s.num}</span>
							<h3 class="step-title">{s.title}</h3>
							<p class="step-desc">{s.desc}</p>
						</div>
					))
				}
			</div>
		</section>

		<!-- ── FAQ ── -->
		<section class="faq">
			<h2 class="section-heading">자주 묻는 질문</h2>
			<div class="faq-list">
				{
					faqs.map((f) => (
						<details class="faq-item">
							<summary class="faq-q">{f.q}</summary>
							<p class="faq-a">{f.a}</p>
						</details>
					))
				}
			</div>
		</section>

		<!-- ── CTA ── -->
		<section class="closing">
			<h2 class="closing-title">도구는 준비되었습니다.</h2>
			<a href={portalUrl} class="closing-cta">Studio Lab 열기</a>
		</section>
	</main>

	<!-- ── Footer ── -->
	<footer class="footer">
		<div class="footer-grid">
			<div class="footer-col">
				<h4 class="footer-heading">Studio</h4>
				<a href="/" class="footer-link">소개</a>
				<a href={portalUrl} class="footer-link">Studio Lab</a>
			</div>
			<div class="footer-col">
				<h4 class="footer-heading">앱</h4>
				{
					STUDIO_APPS.map((app) => (
						<a
							href={`https://${app.domain}`}
							class="footer-link"
							target="_blank"
							rel="noopener"
						>
							{app.name}
						</a>
					))
				}
			</div>
			<div class="footer-col">
				<h4 class="footer-heading">Modfolio</h4>
				<a href="https://modfolio.io" class="footer-link" target="_blank" rel="noopener">modfolio.io</a>
				<a href="https://connect.modfolio.io" class="footer-link" target="_blank" rel="noopener">Connect</a>
				<a href="https://docs.modfolio.io" class="footer-link" target="_blank" rel="noopener">Docs</a>
			</div>
			<div class="footer-col">
				<h4 class="footer-heading">법적 고지</h4>
				<a href="/terms" class="footer-link">이용약관</a>
				<a href="/privacy" class="footer-link">개인정보처리방침</a>
			</div>
		</div>
		<div class="footer-bottom">
			<p>© 2026 Modfolio. All rights reserved.</p>
		</div>
	</footer>
</Base>

<style>
	/* ═══════════════════════════════════════════════
	   Modfolio Studio — Cinematic Landing
	   Scroll = Storytelling. 요소 수 최소, 임팩트 최대.
	   ═══════════════════════════════════════════════ */

	body {
		font-family: var(--font-body);
		background: var(--color-surface-0);
		color: var(--color-text-1);
		min-height: 100vh;
		line-height: 1.6;
	}

	/* ── Nav ── */

	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		padding: var(--space-4) var(--space-8);
		background: color-mix(in oklch, var(--color-surface-0) 70%, transparent);
		backdrop-filter: blur(16px);
	}

	.nav-inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.nav-logo {
		font-family: var(--font-display);
		font-size: var(--font-size-h3);
		font-weight: var(--font-weight-light);
		color: var(--color-text-1);
		text-decoration: none;
		letter-spacing: -0.03em;
	}

	.nav-cta {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		color: var(--color-text-2);
		text-decoration: none;
		padding: var(--space-2) var(--space-4);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-full);
		transition:
			color var(--dur-fast) var(--ease-smooth),
			border-color var(--dur-fast) var(--ease-smooth);
	}

	.nav-cta:hover {
		color: var(--color-text-1);
		border-color: var(--color-text-1);
	}

	/* ── Hero ── */

	.hero {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		padding: var(--space-24) var(--space-6);
		overflow: hidden;
	}

	.hero-glow {
		position: absolute;
		inset: 0;
		background: radial-gradient(
			ellipse 60% 50% at 50% 50%,
			color-mix(in oklch, var(--color-accent-primary) 5%, transparent),
			transparent
		);
		pointer-events: none;
	}

	.hero-content {
		position: relative;
		text-align: center;
		max-width: 900px;
	}

	.hero-title {
		font-family: var(--font-display);
		font-size: var(--font-size-hero);
		font-weight: var(--font-weight-light);
		line-height: 1.15;
		letter-spacing: -0.03em;
		margin-bottom: var(--space-12);
	}

	.hero-cta {
		display: inline-block;
		font-family: var(--font-ui);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		color: var(--color-text-1);
		text-decoration: none;
		padding: var(--space-3) var(--space-8);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-full);
		transition:
			border-color var(--dur-base) var(--ease-smooth),
			transform var(--dur-fast) var(--ease-smooth),
			box-shadow var(--dur-base) var(--ease-smooth);
	}

	.hero-cta:hover {
		border-color: var(--color-accent-primary);
		transform: scale(1.03);
		box-shadow: 0 0 32px color-mix(in oklch, var(--color-accent-primary) 20%, transparent);
	}

	.hero-cta:active {
		transform: scale(0.97);
	}

	/* ── Social Proof ── */

	.proof {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: var(--space-3);
		padding: var(--space-4) var(--space-6);
		border-top: 1px solid var(--color-border-default);
		border-bottom: 1px solid var(--color-border-default);
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-3);
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.proof-sep {
		color: var(--color-accent-primary);
	}

	/* ── App Sections (Fullscreen) ── */

	.app-section {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		padding: var(--space-16) var(--space-6);
		position: relative;
	}

	/* Per-app radial glow background */
	.app-section[data-app="munseo"] {
		background: radial-gradient(
			ellipse 70% 60% at 50% 50%,
			color-mix(in oklch, var(--color-app-munseo) 6%, transparent),
			var(--color-surface-0) 70%
		);
	}

	.app-section[data-app="umbracast"] {
		background: radial-gradient(
			ellipse 70% 60% at 50% 50%,
			color-mix(in oklch, var(--color-app-umbracast) 6%, transparent),
			var(--color-surface-0) 70%
		);
	}

	.app-section[data-app="sincheong"] {
		background: radial-gradient(
			ellipse 70% 60% at 50% 50%,
			color-mix(in oklch, var(--color-app-sincheong) 6%, transparent),
			var(--color-surface-0) 70%
		);
	}

	/* Scroll-driven fade-in */
	.app-section-content {
		text-align: center;
		max-width: 700px;
		animation: fadeUp var(--dur-slow) var(--ease-smooth) both;
		animation-timeline: view();
		animation-range: entry 0% entry 50%;
	}

	@keyframes fadeUp {
		from {
			opacity: 0;
			transform: translateY(var(--space-10));
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Fallback for browsers without view timeline */
	@supports not (animation-timeline: view()) {
		.app-section-content {
			opacity: 1;
			transform: none;
			animation: none;
		}
	}

	.app-label {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin-bottom: var(--space-4);
	}

	.app-section[data-app="munseo"] .app-label {
		color: var(--color-app-munseo);
	}

	.app-section[data-app="umbracast"] .app-label {
		color: var(--color-app-umbracast);
	}

	.app-section[data-app="sincheong"] .app-label {
		color: var(--color-app-sincheong);
	}

	.app-headline {
		font-family: var(--font-display);
		font-size: var(--font-size-display);
		font-weight: var(--font-weight-light);
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-4);
	}

	.app-desc {
		font-family: var(--font-ui);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-3);
	}

	/* ── Section Heading (shared) ── */

	.section-heading {
		font-family: var(--font-display);
		font-size: var(--font-size-h2);
		font-weight: var(--font-weight-light);
		text-align: center;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-12);
	}

	/* ── How It Works ── */

	.how {
		max-width: 1000px;
		margin: 0 auto;
		padding: var(--space-24) var(--space-6);
	}

	.steps {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-8);
	}

	.step {
		padding-left: var(--space-6);
		border-left: 1px solid var(--color-border-default);
	}

	.step-num {
		display: block;
		font-family: var(--font-mono);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-bold);
		color: var(--color-accent-primary);
		margin-bottom: var(--space-3);
	}

	.step-title {
		font-family: var(--font-display);
		font-size: var(--font-size-h3);
		font-weight: var(--font-weight-medium);
		margin-bottom: var(--space-2);
	}

	.step-desc {
		font-family: var(--font-body);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-2);
		line-height: 1.7;
		max-width: 28ch;
	}

	/* ── FAQ ── */

	.faq {
		max-width: 640px;
		margin: 0 auto;
		padding: var(--space-24) var(--space-6);
	}

	.faq-list {
		display: flex;
		flex-direction: column;
	}

	.faq-item {
		border-bottom: 1px solid var(--color-border-default);
	}

	.faq-q {
		font-family: var(--font-ui);
		font-size: var(--font-size-body);
		font-weight: var(--font-weight-medium);
		padding: var(--space-6) 0;
		cursor: pointer;
		list-style: none;
		transition: color var(--dur-fast) var(--ease-smooth);
	}

	.faq-q::-webkit-details-marker {
		display: none;
	}

	.faq-q:hover {
		color: var(--color-accent-primary);
	}

	.faq-a {
		font-family: var(--font-body);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-2);
		line-height: 1.7;
		padding-bottom: var(--space-6);
		max-width: 50ch;
	}

	/* ── Closing CTA ── */

	.closing {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 60vh;
		padding: var(--space-24) var(--space-6);
		text-align: center;
	}

	.closing-title {
		font-family: var(--font-display);
		font-size: var(--font-size-h1);
		font-weight: var(--font-weight-light);
		letter-spacing: -0.02em;
		margin-bottom: var(--space-8);
	}

	.closing-cta {
		display: inline-block;
		font-family: var(--font-ui);
		font-size: var(--font-size-body);
		font-weight: var(--font-weight-medium);
		color: var(--color-surface-0);
		text-decoration: none;
		padding: var(--space-4) var(--space-10);
		background: var(--color-accent-primary);
		border-radius: var(--radius-full);
		transition:
			transform var(--dur-fast) var(--ease-smooth),
			box-shadow var(--dur-base) var(--ease-smooth);
	}

	.closing-cta:hover {
		transform: scale(1.05);
		box-shadow: 0 0 40px color-mix(in oklch, var(--color-accent-primary) 30%, transparent);
	}

	.closing-cta:active {
		transform: scale(0.97);
	}

	/* ── Footer ── */

	.footer {
		background: var(--color-surface-raised);
		border-top: 1px solid var(--color-border-default);
		padding: var(--space-16) var(--space-8) var(--space-8);
	}

	.footer-grid {
		max-width: 1000px;
		margin: 0 auto var(--space-12);
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-8);
	}

	.footer-col {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.footer-heading {
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-text-3);
		margin-bottom: var(--space-2);
	}

	.footer-link {
		font-family: var(--font-body);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-regular);
		color: var(--color-text-2);
		text-decoration: none;
		transition: color var(--dur-fast) var(--ease-smooth);
	}

	.footer-link:hover {
		color: var(--color-text-1);
	}

	.footer-bottom {
		max-width: 1000px;
		margin: 0 auto;
		padding-top: var(--space-8);
		border-top: 1px solid var(--color-border-default);
		font-family: var(--font-ui);
		font-size: var(--font-size-caption);
		color: var(--color-text-3);
	}

	/* ── Responsive ── */

	@media (max-width: 768px) {
		.hero-title {
			font-size: clamp(2rem, 6vw, 3.5rem);
		}

		.app-headline {
			font-size: var(--font-size-h1);
		}

		.steps {
			grid-template-columns: 1fr;
			gap: var(--space-6);
		}

		.footer-grid {
			grid-template-columns: 1fr 1fr;
		}

		.proof {
			flex-wrap: wrap;
			justify-content: center;
		}
	}

	@media (max-width: 480px) {
		.hero-title {
			font-size: clamp(1.75rem, 5vw, 2.5rem);
		}

		.footer-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
