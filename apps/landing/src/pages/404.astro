---
import Base from "../layouts/Base.astro";
---

<Base title="페이지를 찾을 수 없습니다 — Modfolio Studio">
	<main class="error-page">
		<h1 class="error-code">404</h1>
		<p class="error-message">요청하신 페이지를 찾을 수 없습니다.</p>
		<div class="error-links">
			<a href="/" class="error-link">홈으로 돌아가기</a>
			<a href="/apps" class="error-link">앱 둘러보기</a>
		</div>
	</main>
</Base>

<style>
	.error-page {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 80vh;
		padding: var(--header-height) var(--layout-padding-x) var(--space-16);
		text-align: center;
	}

	.error-code {
		font-family: var(--font-mono);
		font-size: var(--font-size-hero);
		font-weight: var(--font-weight-bold);
		color: var(--color-text-3);
		margin-bottom: var(--space-4);
	}

	.error-message {
		font-family: var(--font-body);
		font-size: var(--font-size-body);
		color: var(--color-text-2);
		margin-bottom: var(--space-8);
	}

	.error-links {
		display: flex;
		gap: var(--space-4);
	}

	.error-link {
		font-family: var(--font-ui);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		color: var(--color-text-2);
		text-decoration: none;
		padding: var(--space-3) var(--space-6);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-full);
		transition:
			color var(--dur-fast) var(--ease-smooth),
			border-color var(--dur-fast) var(--ease-smooth);
	}

	.error-link:hover {
		color: var(--color-text-1);
		border-color: var(--color-text-1);
	}
</style>
