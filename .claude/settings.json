{
	"permissions": {
		"allow": [
			"Bash(bun run quality:all)",
			"Bash(bun run quality:*)",
			"Bash(bun run build)",
			"Bash(bun run build:*)",
			"Bash(bun run dev)",
			"Bash(bun run dev:*)",
			"Bash(bun run check:*)",
			"Bash(bun run check)",
			"Bash(bun run typecheck)",
			"Bash(bun run typecheck:*)",
			"Bash(bun run harness-pull)",
			"Bash(bun run harness-pull:*)",
			"Bash(bun run modfolio)",
			"Bash(bun run modfolio:*)",
			"Bash(bun run test:*)",
			"Bash(bun run lint)",
			"Bash(bun run lint:*)",
			"Bash(bun run format)",
			"Bash(bun run format:*)",
			"Bash(bun run preview)",
			"Bash(bun run preview:*)",
			"Bash(bash scripts/quality-gate.sh*)"
		],
		"defaultMode": "bypassPermissions",
		"deny": [
			"Write(.claude/payment-approval.json)",
			"Edit(.claude/payment-approval.json)",
			"Bash(*payment-approval.json*)"
		]
	},
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "bun run check 2>&1 | tail -8"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bun run \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-destructive-guard.ts\""
					},
					{
						"type": "command",
						"command": "bun run \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-payment-guard.ts\""
					}
				]
			},
			{
				"matcher": "mcp__.*",
				"hooks": [
					{
						"type": "command",
						"command": "bun run \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-payment-guard.ts\""
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "bash scripts/quality-gate.sh 2>&1 | tail -30"
					},
					{
						"type": "agent",
						"prompt": "Read /tmp is not needed. Instead, run `bash scripts/quality-gate.sh 2>&1` and read the output.\n\nIf the output contains 'PASS', respond {\"ok\": true}.\n\nIf the output contains 'FAIL':\n1. Read memory/pattern-history.md\n2. For each violation pattern in the output:\n   - If the pattern already exists in the table: increment count, update date to today\n   - If new: append row: | pattern description | 1 | today's date | TRACKING |\n   - If any pattern count reaches 3: change status to ESCALATE\n3. Write updated memory/pattern-history.md\n4. Respond {\"ok\": false, \"reason\": \"<summary of violations>\"}\n\nRESPONSE FORMAT: You MUST respond with ONLY a JSON object, no other text.",
						"timeout": 15
					}
				]
			}
		]
	},
	"env": {
		"CLAUDE_CODE_EFFORT_LEVEL": "max"
	}
}
